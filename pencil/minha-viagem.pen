                          "padding": [8, 12],
                          "height": 40,
                          "cornerRadius": 6,
                          "fill": "$surface-primary",
                          "stroke": { "thickness": 1, "fill": "$border-subtle" },
                          "children": [
                            { "type": "text", "content": "seu@email.com", "fontFamily": "Inter", "fontSize": 14, "fill": "$foreground-muted" }
                          ]
