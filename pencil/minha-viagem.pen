{
  "version": "2.11",
  "variables": {
    "surface-primary": { "type": "color", "value": "#FFFFFF" },
    "surface-inverse": { "type": "color", "value": "#1A1A1A" },
    "foreground-primary": { "type": "color", "value": "#1A1A1A" },
    "foreground-secondary": { "type": "color", "value": "#666666" },
    "foreground-muted": { "type": "color", "value": "#999999" },
    "foreground-inverse": { "type": "color", "value": "#FFFFFF" },
    "border-subtle": { "type": "color", "value": "#E4E4E7" },
    "accent-primary": { "type": "color", "value": "#0066FF" },
    "bg-zinc-50": { "type": "color", "value": "#FAFAFA" },
    "bg-zinc-100": { "type": "color", "value": "#F4F4F5" },
    "bg-zinc-200": { "type": "color", "value": "#E4E4E7" },
    "bg-zinc-900": { "type": "color", "value": "#18181B" },
    "text-zinc-50": { "type": "color", "value": "#FAFAFA" },
    "text-zinc-400": { "type": "color", "value": "#A1A1AA" },
    "text-zinc-500": { "type": "color", "value": "#71717A" },
