                      "type": "frame",
                      "layout": "vertical",
                      "gap": 6,
                      "children": [
                        { "type": "text", "content": "Senha", "fontFamily": "Inter", "fontSize": 14, "fontWeight": "500", "fill": "$foreground-primary" },
                        {
                          "type": "frame",
                          "layout": "horizontal",
                          "alignItems": "center",
                          "padding": [8, 12],
                          "height": 40,
                          "cornerRadius": 6,
