{
  "name": "minha-viagem",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "dev:web": "turbo dev --filter=@minha-viagem/web",
    "build:web": "turbo build --filter=@minha-viagem/web"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.6",
    "prettier": "^3.8.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.4"
  },
  "packageManager": "pnpm@9.15.0"
}
